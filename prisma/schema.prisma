// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================
enum Role {
  ADMIN
  STUDENT
}

enum FormType {
  QUIZ
  TEST
  ASSIGNMENT
}

enum SubmissionStatus {
  PENDING
  GRADED
  RETURNED
}

// ============================================
// USERS
// ============================================
model User {
  id             String         @id @default(cuid())
  clerkId        String         @unique
  email          String         @unique
  name           String?
  role           Role           @default(STUDENT)

  // Relations
  announcements  Announcement[]
  videos         Video[]
  courses        Course[]       // Courses created by user
  enrollments    Enrollment[]   // Courses enrolled in
  lectureSlides  LectureSlide[]
  quizzes        Quiz[]
  tests          Test[]
  assignments    Assignment[]
  quizSubmissions QuizSubmission[]
  testSubmissions TestSubmission[]
  assignmentSubmissions AssignmentSubmission[]
  lessonCompletions LessonCompletion[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([role])
  @@index([email])
}

// ============================================
// ANNOUNCEMENTS
// ============================================
model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  author    User     @relation(fields: [authorId], references: [clerkId])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([authorId])
}

// ============================================
// VIDEOS
// ============================================
model Video {
  id           String   @id @default(cuid())
  title        String
  description  String?
  cloudinaryId String?
  url          String
  thumbnail    String?
  source       String?
  youtubeId    String?
  uploadedBy   String
  uploader     User     @relation(fields: [uploadedBy], references: [clerkId])
  lessons      Lesson[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
  @@index([uploadedBy])
  @@index([source])
}

// ============================================
// COURSE STRUCTURE
// ============================================

model Course {
  id          String   @id @default(cuid())
  code        String   @unique
  title       String
  description String?
  thumbnail   String?
  category    String?
  level       String?

  modules     Module[]
  enrollments Enrollment[]
  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [clerkId])

  // Reverse relation for lecture slides
  lectureSlides LectureSlide[]

  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@index([createdAt])
  @@index([createdBy])
}

model Module {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)

  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courseId])
  @@index([order])
  @@index([courseId, order])
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)

  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  videoId     String?
  video       Video?   @relation(fields: [videoId], references: [id])
  slidesId    String?
  slides      LectureSlide? @relation(fields: [slidesId], references: [id])
  quizId      String?
  quiz        Quiz?    @relation(fields: [quizId], references: [id])

  completions LessonCompletion[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([moduleId])
  @@index([order])
  @@index([moduleId, order])
}

// ============================================
// ✅ UPDATED LECTURE SLIDES (with file support)
// ============================================
model LectureSlide {
  id          String   @id @default(cuid())
  title       String
  description String?
  embedUrl    String?   // Google Slides embed URL (optional, only for Google Slides)
  fileUrl     String?   // URL for uploaded PDF (optional)
  contentType String?   // 'google_slides' or 'pdf'
  order       Int      @default(0)
  category    String?   // e.g., "Computer Science", "Mathematics"
  courseId    String?   // optional link to a course
  course      Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [clerkId])
  lessons     Lesson[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courseId])
  @@index([category])
  @@index([createdAt])
  @@index([createdBy])
}

// ============================================
// QUIZZES (Google Forms + Files)
// ============================================
model Quiz {
  id          String   @id @default(cuid())
  title       String
  description String?
  embedUrl    String
  formUrl     String
  dueDate     DateTime?
  fileUrl     String?
  contentType String?   // 'google_form', 'pdf', 'image', 'past_paper'

  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [clerkId])
  lessons     Lesson[]
  submissions QuizSubmission[]

  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([isPublished])
}

model QuizSubmission {
  id          String   @id @default(cuid())
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [clerkId])

  score       Int?
  total       Int?
  feedback    String?

  status      SubmissionStatus @default(PENDING)
  submittedAt DateTime @default(now())
  gradedAt    DateTime?
  gradedBy    String?

  responseId  String?

  @@index([userId])
  @@index([quizId])
}

// ============================================
// TESTS (Google Forms + Files)
// ============================================
model Test {
  id          String   @id @default(cuid())
  title       String
  description String?
  embedUrl    String
  formUrl     String
  dueDate     DateTime?
  maxScore    Int?
  fileUrl     String?
  contentType String?   // 'google_form', 'pdf', 'image', 'past_paper'

  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [clerkId])
  submissions TestSubmission[]

  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([isPublished])
}

model TestSubmission {
  id          String   @id @default(cuid())
  testId      String
  test        Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [clerkId])

  score       Int?
  total       Int?
  feedback    String?

  status      SubmissionStatus @default(PENDING)
  submittedAt DateTime @default(now())
  gradedAt    DateTime?
  gradedBy    String?

  responseId  String?

  @@index([userId])
  @@index([testId])
}

// ============================================
// ASSIGNMENTS (Google Forms + Files)
// ============================================
model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String?
  embedUrl    String
  formUrl     String
  dueDate     DateTime?
  maxScore    Int?
  fileUrl     String?
  contentType String?   // 'google_form', 'pdf', 'image', 'past_paper'

  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [clerkId])
  submissions AssignmentSubmission[]

  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([isPublished])
}

model AssignmentSubmission {
  id          String   @id @default(cuid())
  assignmentId String
  assignment  Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [clerkId])

  score       Int?
  total       Int?
  feedback    String?

  status      SubmissionStatus @default(PENDING)
  submittedAt DateTime @default(now())
  gradedAt    DateTime?
  gradedBy    String?

  responseId  String?
  fileUrl     String?

  @@index([userId])
  @@index([assignmentId])
}

// ============================================
// ENROLLMENT
// ============================================
model Enrollment {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [clerkId])

  progress    Int      @default(0)
  enrolledAt  DateTime @default(now())

  @@unique([courseId, userId])
  @@index([userId])
  @@index([courseId])
  @@index([enrolledAt])
}

// ============================================
// ✅ LESSON COMPLETIONS
// ============================================
model LessonCompletion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}